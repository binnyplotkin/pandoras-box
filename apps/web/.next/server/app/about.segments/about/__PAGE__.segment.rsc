:"var(--foreground)"},"children":[["$","div",null,{"className":"space-y-5","children":[["$","p",null,{"className":"text-sm uppercase tracking-widest opacity-40","style":{"fontFamily":"var(--font-mono)"},"children":"I. The Question"}],["$","h2",null,{"className":"text-3xl font-bold","style":{"fontFamily":"var(--font-display)"},"children":"It Started on a Rock"}],["$","p",null,{"className":"text-lg leading-relaxed opacity-80","children":["Somewhere in Central Park, on an unremarkable afternoon that turned out to be remarkably important, ",["$","strong",null,{"children":"Binny Plotkin"}]," and ",["$","strong",null,{"children":"Josh Sassoon"}]," were sitting on a boulder — the way serious people sit when they're trying to think about something bigger than themselves."]}],["$","p",null,{"className":"text-lg leading-relaxed opacity-80","children":"The conversation had that particular quality where the words start saying themselves, and you're really just listening. They talked about identity. About imagination. About the strange human ache of wanting to know what it would feel like to be someone entirely different — not to escape your life, but to understand it more deeply."}],["$","blockquote",null,{"className":"text-2xl font-medium italic pl-6 py-3 my-4","style":{"borderLeft":"3px solid var(--accent)","color":"var(--accent-strong)"},"children":["“What would it actually ",["$","em",null,{"children":"feel like"}]," to be a king?”"]}],["$","p",null,{"className":"text-lg leading-relaxed opacity-80","children":"Not a metaphorical king. Not a chess piece. A real one — with weight and responsibility, with subjects who need things from you and advisors who may or may not be plotting something. The texture of a different life, fully inhabited."}],["$","p",null,{"className":"text-lg leading-relaxed opacity-80","children":"That question cracked something open. And Pandora's Box was born in the space between the asking and the answer."}]]}],"$L4","$L5","$L6","$L7","$L8","$L9","$La"