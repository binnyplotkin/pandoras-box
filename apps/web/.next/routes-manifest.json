{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/sessions/[sessionId]",
      "regex": "^/api/sessions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPsessionId": "nxtPsessionId"
      },
      "namedRegex": "^/api/sessions/(?<nxtPsessionId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/sessions/[sessionId]/turns",
      "regex": "^/api/sessions/([^/]+?)/turns(?:/)?$",
      "routeKeys": {
        "nxtPsessionId": "nxtPsessionId"
      },
      "namedRegex": "^/api/sessions/(?<nxtPsessionId>[^/]+?)/turns(?:/)?$"
    },
    {
      "page": "/api/worlds/[worldId]",
      "regex": "^/api/worlds/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPworldId": "nxtPworldId"
      },
      "namedRegex": "^/api/worlds/(?<nxtPworldId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/simulation/[sessionId]",
      "regex": "^/simulation/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPsessionId": "nxtPsessionId"
      },
      "namedRegex": "^/simulation/(?<nxtPsessionId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/api/audio/speak",
      "regex": "^/api/audio/speak(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/audio/speak(?:/)?$"
    },
    {
      "page": "/api/audio/transcribe",
      "regex": "^/api/audio/transcribe(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/audio/transcribe(?:/)?$"
    },
    {
      "page": "/api/audio/voices",
      "regex": "^/api/audio/voices(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/audio/voices(?:/)?$"
    },
    {
      "page": "/api/engine/trace",
      "regex": "^/api/engine/trace(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/engine/trace(?:/)?$"
    },
    {
      "page": "/api/sessions",
      "regex": "^/api/sessions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/sessions(?:/)?$"
    },
    {
      "page": "/api/worlds",
      "regex": "^/api/worlds(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/worlds(?:/)?$"
    },
    {
      "page": "/api/worlds/build",
      "regex": "^/api/worlds/build(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/worlds/build(?:/)?$"
    },
    {
      "page": "/builder",
      "regex": "^/builder(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/builder(?:/)?$"
    },
    {
      "page": "/debug/voices",
      "regex": "^/debug/voices(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/debug/voices(?:/)?$"
    },
    {
      "page": "/engine",
      "regex": "^/engine(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/engine(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}